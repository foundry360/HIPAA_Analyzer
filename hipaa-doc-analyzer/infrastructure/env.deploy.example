# Copy to .env.deploy in this folder (gitignored). Loaded automatically for cdk deploy / npm run deploy:frontend.
# Values here are baked into Lambda on each deploy; the AWS Console cannot persist edits across deploys.

DB_PASSWORD=

# Optional admin bootstrap
# ADMIN_EMAILS=
# ADMIN_USERNAMES=
# PRIMARY_ADMIN_SUB=
# PRIMARY_ADMIN_EMAIL=

# Billing (optional)
# STRIPE_SECRET_KEY=
# BILLING_COST_TAG_KEY=tenant_id

# GHL (optional — monthly billing sync writes AWS usage to a contact custom field)
# GHL_API_KEY=
# GHL_LOCATION_ID=
# GHL_CUSTOM_FIELD_ID_AWS_USD=
