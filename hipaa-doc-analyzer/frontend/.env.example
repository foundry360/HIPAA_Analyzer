VITE_API_BASE_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod
# Optional (local dev only): route API calls through Vite at /dev-api so the browser does not block
# cross-origin responses (e.g. if a route is missing and API Gateway omits CORS on the error).
# VITE_DEV_API_PROXY=true
VITE_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
